# ============================================================
# Copy this file to ".env" for local development, and enter the
# same values in Vercel (Project → Settings → Environment Variables)
# for the live deployment. Never commit your real .env file.
# ============================================================

# Your Google service account email address.
# Found in the JSON file you downloaded from Google Cloud Console.
# Looks like: something@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# Your Google service account private key.
# Open the JSON file, find "private_key", copy the whole value
# including the BEGIN and END lines.
# Tip: keep the \n characters exactly as they appear in the JSON —
# the app converts them back into real line breaks automatically.
GOOGLE_PRIVATE_KEY=

# This client's Google Sheet ID.
# Open the Sheet. The ID is the long string in the URL between /d/ and /edit.
GOOGLE_SHEET_ID=

# Admin username — you set this, you share it with the client.
ADMIN_USERNAME=

# Admin starter PIN — the admin changes it on first login.
ADMIN_PIN=
